# ─────────────────────────────────────────────────────────────────
# TimeOff app — environment template
# Copy this file to `.env` and fill in real values for local dev.
# In production (e.g. Netlify) set these in the dashboard's env panel.
# ─────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────
# Local dev (SQLite, default):
DATABASE_URL="file:./dev.db"

# Production (recommended): Turso / libSQL — SQLite-compatible, serverless.
# DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="..."
#
# Or any Postgres URL — requires switching the Prisma datasource provider
# in prisma/schema.prisma and the adapter in src/lib/db.ts.
# DATABASE_URL="postgresql://user:pass@host:5432/db"

# ─── NextAuth ────────────────────────────────────────────────────
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Public URL of your deployment (no trailing slash). Required in production.
NEXTAUTH_URL="http://localhost:3000"

# ─── EmailJS (optional) ─────────────────────────────────────────
# Used for invite + request-status emails. Leave blank to disable.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_INVITE_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

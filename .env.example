# ─────────────────────────────────────────────────────────────────
# TimeOff app — environment template
# Copy this file to `.env` and fill in real values for local dev.
# ─────────────────────────────────────────────────────────────────

# ─── Database (Supabase Postgres) ────────────────────────────────
# Use the Supabase "Session pooler" URL (port 5432 on the pooler host).
# It works for both runtime queries and prisma migrate.
# Find it in: Supabase dashboard → Connect → Session pooler.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Public URL of your deployment (no trailing slash). Required in production.
NEXTAUTH_URL="http://localhost:3000"

# ─── EmailJS (optional) ─────────────────────────────────────────
# Used for invite + request-status emails. Leave blank to disable.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_INVITE_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""
